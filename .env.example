# =============================================================================
# WealthMarg Auto Blog Publisher — Local Development Environment Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to GitHub — it is already in .gitignore
# =============================================================================

# ── Google OAuth ──────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Found in the Sheets URL: docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=your-spreadsheet-id-here

# ── WordPress ─────────────────────────────────────────────────────────────────
# WP_URL: Full URL of your WordPress site (no trailing slash)
# WP_APP_PASSWORD: Generated in WP Admin → Users → Profile → Application Passwords
WP_URL=https://www.wealthmarg.com
WP_USERNAME=your-wp-username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── Mistral AI (PRIMARY — content generation) ─────────────────────────────────
# Get from: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your-mistral-api-key-here

# ── Gemini AI (FALLBACK — key rotation) ───────────────────────────────────────
# JSON array of Gemini API keys — supports multiple keys for rate-limit rotation
# Get keys from: https://aistudio.google.com/app/apikey
GEMINI_API_KEYS=["AIzaSy...key1", "AIzaSy...key2"]

# ── Telegram Notifications ────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram to get the token
# Get your chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=123456789:ABCdef-your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── Optional Scheduling Overrides ─────────────────────────────────────────────
# How many hours between scheduled publishes (default: 2)
PUBLISH_INTERVAL_HOURS=2
# Hour of the day (24h) to send the daily report (default: 21 = 9PM IST)
REPORT_HOUR=21
